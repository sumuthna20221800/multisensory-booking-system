PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/multisensory_booking?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
MAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password>
MAIL_FROM="EcoSenses <no-reply@ecosenses.com>"
ADMIN_NOTIFICATION_EMAILS=ops@ecosenses.com
# Mail health endpoint: GET /api/mail/health
# CLI check: npm run mail:check
